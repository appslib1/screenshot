<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/primaryTextColor"
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rateOurApp"/>
    <TextView
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:text="@string/hearUrFeedback"
        android:textAlignment="center"/>
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageButton
            android:id="@+id/star1"
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/baseline_star_24"
            android:contentDescription="@string/star1"/>
        <ImageButton
            android:id="@+id/star2"
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/baseline_star_24"
            android:contentDescription="@string/star2"/>
        <ImageButton
            android:id="@+id/star3"
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/baseline_star_24"
            android:contentDescription="@string/star3"/>
        <ImageButton
            android:id="@+id/star4"
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/baseline_star_24"
            android:contentDescription="@string/star4"/>
        <ImageButton
            android:id="@+id/star5"
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/baseline_star_24"
            android:contentDescription="@string/star5"/>
    </LinearLayout>
    <com.google.android.material.button.MaterialButton
        android:theme="@style/Theme.MaterialComponents"
        android:textSize="12sp"
        android:textColor="@color/white"
        android:id="@+id/submitRatingButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/submit"
        android:textAllCaps="false"
        app:backgroundTint="@color/primaryColor"
        app:cornerRadius="8dp"
        app:strokeColor="@color/primaryTextColor"/>
</LinearLayout>
